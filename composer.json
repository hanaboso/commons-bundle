{
    "name": "hanaboso/commons-bundle",
    "version": "2.2.0",
    "license": "Apache-2.0",
    "require": {
        "php": "^7.4",
        "guzzlehttp/guzzle": "^7.2",
        "hanaboso/utils": "^1.0",
        "phpseclib/phpseclib": "^2.0",
        "windwalker/crypt": "^3.5"
    },
    "require-dev": {
        "aws/aws-sdk-php-symfony": "^2.2",
        "doctrine/doctrine-bundle": "^2.1",
        "doctrine/mongodb-odm-bundle": "^4.2",
        "php-imap/php-imap": "^4.1",
        "hanaboso/php-check-utils": "^1.1",
        "symfony/mailer": "^5.1",
        "symfony/monolog-bundle": "^3.6",
        "symfony/yaml": "^5.1"
    },
    "suggest": {
        "aws/aws-sdk-php-symfony": "",
        "doctrine/doctrine-bundle": "",
        "doctrine/mongodb-odm-bundle": "",
        "php-imap/php-imap": ""
    },
    "autoload": {
        "psr-4": {
